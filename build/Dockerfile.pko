FROM scratch

LABEL com.redhat.component="openshift-pagerduty-operator" \
      io.k8s.description="pagerduty-operator PKO Package for OpenShift Dedicated" \
      description="pagerduty-operator PKO Package for OpenShift Dedicated" \
      distribution-scope="public" \
      name="openshift/pagerduty-operator-pko" \
      url="https://github.com/openshift/pagerduty-operator" \
      vendor="Red Hat, Inc." \
      release="v0.0.0" \
      version="v0.0.0"

COPY * /package/
